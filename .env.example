# ─── Moodle ───────────────────────────────────────────────────────────────────
# URL base del sitio Moodle (sin slash final)
MOODLE_URL=https://aulavirtual.pds.edu.ar

# Token del servicio "Legajo API" (nunca exponer en el frontend)
MOODLE_TOKEN=tu_token_de_moodle_aqui

# ─── Base de datos MySQL ──────────────────────────────────────────────────────
# Formato: mysql://usuario:contraseña@host:puerto/nombre_base
# En Nuthost cPanel el usuario suele ser: cpanelusuario_nombre
# El host en producción (misma máquina) generalmente es: localhost
DATABASE_URL=mysql://usuario:contraseña@localhost:3306/nombre_base

# ─── Sesión ───────────────────────────────────────────────────────────────────
# Secreto para firmar cookies de sesión. Mínimo 32 caracteres aleatorios.
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio

# ─── Entorno ──────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Uploads (salidas didácticas / documentos) ────────────────────────────────
# Ruta absoluta donde se guardan los archivos subidos por docentes.
# En producción (cPanel): ruta fuera de public_html, ej: /home/usuario/uploads
# En desarrollo: puede ser ./uploads (se crea automáticamente)
UPLOAD_DIR=./uploads
